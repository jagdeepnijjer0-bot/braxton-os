# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key — server-side only. Never expose to the browser.
# Used by public form submissions to bypass RLS.
# Found in: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── n8n Integration ───────────────────────────────────────────────────────────
# Master switch — set to "true" to enable all outbound webhooks
N8N_ENABLED=true

# Shared HMAC secret — used to sign outbound payloads AND verify inbound requests.
# Generate with: openssl rand -hex 32
N8N_WEBHOOK_SECRET=your-hmac-secret-here

# Base URL for your self-hosted n8n instance.
# Outbound events will POST to: <base>/<event-slug>
# e.g. https://n8n.yourcompany.com/webhook/braxton-os/new-contact
N8N_WEBHOOK_BASE_URL=https://n8n.yourcompany.com/webhook/braxton-os

# ── Per-event overrides (optional) ───────────────────────────────────────────
# If set, these URLs take precedence over the base URL for that event.
# N8N_WEBHOOK_NEW_CONTACT=
# N8N_WEBHOOK_HOT_LEAD=
# N8N_WEBHOOK_OUTREACH_REPLY=
# N8N_WEBHOOK_WEBSITE_LEAD=
# N8N_WEBHOOK_OVERDUE_FOLLOWUP=
# N8N_WEBHOOK_TASK_OVERDUE=
# N8N_WEBHOOK_DEAL_STAGE_CHANGED=

# ── Per-event n8n webhook URL overrides (optional — uses base URL by default)
# N8N_WEBHOOK_LEAD_UPDATED=
# N8N_WEBHOOK_TASK_CREATED=
# N8N_WEBHOOK_MESSAGE_RECEIVED=
# N8N_WEBHOOK_DEAL_UPDATED=
# N8N_WEBHOOK_FILE_UPLOADED=

# ── Cron jobs ─────────────────────────────────────────────────────────────────
# Secret for the /api/webhooks/cron/* endpoints.
# Callers must send: Authorization: Bearer <CRON_SECRET>
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here

# ── Meta / Instagram Integration ──────────────────────────────────────────────
# Webhook verify token — set this to any random string.
# Paste the SAME string into: Meta Developer Console → App → Webhooks → Verify Token
# Generate with: openssl rand -hex 16
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

META_WEBHOOK_VERIFY_TOKEN=your-verify-token-here

# Meta App Secret — used to verify X-Hub-Signature-256 on inbound webhooks.
# Found in: Meta Developer Console → App → Settings → Basic → App Secret
META_APP_SECRET=your-app-secret-here

# Page Access Tokens — needed to SEND messages (future / Phase 3F).
# Not required to receive webhooks.
# META_PAGE_ACCESS_TOKEN_INSTAGRAM=your-instagram-page-token
# META_PAGE_ACCESS_TOKEN_FACEBOOK=your-facebook-page-token
